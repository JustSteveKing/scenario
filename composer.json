{
  "name": "juststeveking/scenario",
  "description": "A type-safe, railway-oriented business logic orchestration engine for PHP 8.5+.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "orchestration",
    "saga",
    "scenario",
    "workflow",
    "business-logic",
    "railway-oriented"
  ],
  "authors": [
    {
      "name": "Steve McDougall",
      "email": "steve@juststeveking.com",
      "homepage": "https://juststeveking.link/",
      "role": "Developer"
    }
  ],
  "homepage": "https://github.com/JustSteveKing/scenario",
  "require": {
    "php": "^8.5"
  },
  "require-dev": {
    "laravel/pint": "^1.29",
    "orchestra/testbench": "^11.0",
    "phpstan/phpstan": "^2.1.46",
    "phpstan/phpstan-strict-rules": "^2.0.10",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "JustSteveKing\\Scenario\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "JustSteveKing\\Scenario\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": [
      "./vendor/bin/pint --test --parallel"
    ],
    "pint": [
      "./vendor/bin/pint --parallel"
    ],
    "stan": [
      "./vendor/bin/phpstan analyse"
    ],
    "test": [
      "./vendor/bin/phpunit --testdox"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "laravel": {
      "providers": [
        "JustSteveKing\\Scenario\\Providers\\ScenarioServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
