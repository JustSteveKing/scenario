{
  "name": "juststeveking/scenario",
  "description": "A strictly typed, railway-oriented business logic orchestration engine for PHP and Laravel.",
  "keywords": [
    "laravel",
    "workflow",
    "orchestration",
    "saga",
    "railway-oriented-programming",
    "type-safe",
    "business-logic"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Steve McDougall",
      "email": "steve@treblle.com"
    }
  ],
  "require": {
    "php": "^8.5",
    "juststeveking/result": "^1.0",
    "psr/log": "^1.0|^2.0|^3.0"
  },
  "autoload": {
    "psr-4": {
      "JustSteveKing\\Scenario\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "JustSteveKing\\Scenario\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "orchestra/testbench": "^11.0",
    "roave/security-advisories": "dev-latest",
    "phpstan/phpstan": "^2.1.46",
    "phpstan/phpstan-strict-rules": "^2.0.10",
    "laravel/pint": "^1.29"
  },
  "scripts": {
    "lint": [
      "./vendor/bin/pint --test --parallel"
    ],
    "pint": [
      "./vendor/bin/pint --parallel"
    ],
    "stan": [
      "./vendor/bin/phpstan analyse"
    ],
    "test": [
      "./vendor/bin/phpunit --testdox"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "JustSteveKing\\Scenario\\Providers\\ScenarioServiceProvider"
      ]
    }
  }
}
